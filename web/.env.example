# Sanity — fill these from your project (sanity.io/manage) then copy to .env.local
NEXT_PUBLIC_SANITY_PROJECT_ID=your-project-id
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2026-03-01

# Server-only read token (Editor/Viewer). Unlocks draft preview + click-to-edit.
SANITY_API_READ_TOKEN=

# Optional: production site origin for the Presentation preview iframe.
# Defaults to http://localhost:3000 in development.
# NEXT_PUBLIC_SITE_URL=https://your-site.vercel.app
